{
  "expo": {
    "name": "FilmRoulette",
    "slug": "FilmRoulette",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/popcorn.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/popcorn.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/popcorn.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./src/assets/popcorn.png"
    },
    "plugins": ["expo-router"],
    "scheme": "filmroulette",
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
